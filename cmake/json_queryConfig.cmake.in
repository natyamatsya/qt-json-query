@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Qt6 COMPONENTS Core Network)

# IDN backend — only relevant when the installed build enabled it
set(_json_query_format_idn "@JSON_QUERY_FORMAT_IDN@")
set(_json_query_idn_backend "@JSON_QUERY_IDN_BACKEND@")
if(_json_query_format_idn AND _json_query_idn_backend STREQUAL "libidn2")
  find_path(IDN2_INCLUDE_DIR idn2.h)
  find_library(IDN2_LIBRARY NAMES idn2)
  if(NOT IDN2_LIBRARY)
    set(${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE
        "json_query was built with the libidn2 IDN backend, but libidn2 was not found")
    set(${CMAKE_FIND_PACKAGE_NAME}_FOUND FALSE)
    return()
  endif()
  if(NOT TARGET idn2::idn2)
    add_library(idn2::idn2 UNKNOWN IMPORTED)
    set_target_properties(
      idn2::idn2 PROPERTIES IMPORTED_LOCATION "${IDN2_LIBRARY}"
                            INTERFACE_INCLUDE_DIRECTORIES "${IDN2_INCLUDE_DIR}")
  endif()
endif()
unset(_json_query_format_idn)
unset(_json_query_idn_backend)

include("${CMAKE_CURRENT_LIST_DIR}/json_queryTargets.cmake")

check_required_components(json_query)
