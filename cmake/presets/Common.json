{
  "version": 9,
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "displayName": "Common",
      "description": "Shared settings for all builds",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-${presetName}"
    },
    {
      "name": "common-apple-clang",
      "inherits": "common",
      "hidden": true,
      "displayName": "Common Apple Clang",
      "description": "Shared settings for Apple Clang builds",
      "toolchainFile": "${sourceDir}/cmake/toolchains/apple-clang.cmake"
    },
    {
      "name": "common-llvm-clang",
      "inherits": "common",
      "hidden": true,
      "displayName": "Common LLVM Clang",
      "description": "Shared settings for LLVM Clang builds",
      "toolchainFile": "${sourceDir}/cmake/toolchains/llvm-clang.cmake"
    },
    {
      "name": "common-msvc",
      "inherits": "common",
      "hidden": true,
      "displayName": "Common MSVC",
      "description": "Shared settings for MSVC builds",
      "toolchainFile": "${sourceDir}/cmake/toolchains/msvc.cmake"
    }
    ,
    {
      "name": "common-clang-cl",
      "inherits": "common",
      "hidden": true,
      "displayName": "Common clang-cl",
      "description": "Shared settings for Windows builds with clang-cl",
      "toolchainFile": "${sourceDir}/cmake/toolchains/clang-cl.cmake"
    },
    {
      "name": "common-gcc",
      "inherits": "common",
      "hidden": true,
      "displayName": "Common GCC",
      "description": "Shared settings for GCC builds",
      "toolchainFile": "${sourceDir}/cmake/toolchains/gcc.cmake"
    }
  ]
}
