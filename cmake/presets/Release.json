{
  "version": 9,
  "include": [
    "Common.json"
  ],
  "configurePresets": [
    {
      "name": "release",
      "inherits": "common",
      "displayName": "Release",
      "description": "Release build with optimizations",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-apple-clang",
      "inherits": "common-apple-clang",
      "displayName": "Release (Apple Clang)",
      "description": "Release build with Apple Clang compiler",
      "binaryDir": "${sourceDir}/build-release-apple-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-llvm-clang",
      "inherits": "common-llvm-clang",
      "displayName": "Release (LLVM Clang)",
      "description": "Release build with LLVM Clang compiler",
      "binaryDir": "${sourceDir}/build-release-llvm-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-msvc",
      "inherits": "common-msvc",
      "displayName": "Release (MSVC)",
      "description": "Release build with Microsoft Visual C++",
      "binaryDir": "${sourceDir}/build-release-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
    ,
    {
      "name": "release-clang-cl",
      "inherits": "common-clang-cl",
      "displayName": "Release (clang-cl)",
      "description": "Release build with clang-cl on Windows",
      "binaryDir": "${sourceDir}/build-release-clang-cl",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "description": "Build release configuration",
      "jobs": 8
    },
    {
      "name": "release-apple-clang",
      "configurePreset": "release-apple-clang",
      "description": "Build release configuration with Apple Clang",
      "jobs": 8
    },
    {
      "name": "release-llvm-clang",
      "configurePreset": "release-llvm-clang",
      "description": "Build release configuration with LLVM Clang",
      "jobs": 8
    },
    {
      "name": "release-msvc",
      "configurePreset": "release-msvc",
      "description": "Build release configuration with MSVC",
      "jobs": 8
    }
    ,
    {
      "name": "release-clang-cl",
      "configurePreset": "release-clang-cl",
      "description": "Build release configuration with clang-cl",
      "jobs": 8
    }
  ]
}
